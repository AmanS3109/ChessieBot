{
  "name": "ChessieBot Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.pylint",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
  "remoteEnv": {
    "GROQ_API_KEY": "${localEnv:GROQ_API_KEY}"
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.chessiebot-data,target=/workspaces/ChessieBot/data/processed/chromadb,type=bind,consistency=cached"
  ]
}
